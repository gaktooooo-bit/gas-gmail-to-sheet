/**
 * Config.gs
 * ------------------------------------------------------------------
 * このファイルだけ編集すれば、本体コードを触らず挙動を変えられます。
 *
 * ■ 仕組みの考え方
 *   「処理対象ラベル」が付いた未処理メールを定期的に拾い、内容をシートへ
 *   転記したら「処理済みラベル」を付け替えます。これにより同じメールを
 *   二重に転記しません。Gmailのフィルタで対象メールに自動でラベルを
 *   付けておくと、完全自動で回ります（README参照）。
 * ------------------------------------------------------------------
 */

const CONFIG = {
  // ── 転記先シート ─────────────────────────────────────────
  SHEET_NAME: '受信ログ',

  // ── Gmailラベル ──────────────────────────────────────────
  // 処理対象のラベル（このラベルが付いた未処理メールを拾う）
  TARGET_LABEL: '自動転記',
  // 処理が終わったメールに付け替えるラベル（無ければ自動作成）
  DONE_LABEL: '転記済み',

  // ── 1回あたりの処理上限（実行時間オーバー防止）────────────
  MAX_THREADS_PER_RUN: 20,

  // ── 抽出ルール ───────────────────────────────────────────
  // メール本文から取り出したい項目を「見出し」と「正規表現」で定義。
  // 正規表現の最初の丸カッコ ( ) の中身が抽出されます。
  // 見つからなければ空欄になります（エラーにはしません）。
  PARSE_RULES: [
    { header: '注文番号', pattern: '注文番号[\\s:：]*([A-Za-z0-9\\-]+)' },
    { header: '金額', pattern: '(?:金額|合計)[\\s:：]*([0-9,]+)\\s*円' },
    { header: '電話番号', pattern: '(0\\d{1,4}-\\d{1,4}-\\d{3,4})' },
  ],

  // 本文の先頭を「本文抜粋」として残す文字数（0で無効）
  BODY_SNIPPET_LENGTH: 200,

  // ── Slack通知（任意）────────────────────────────────────
  SLACK: {
    ENABLED: false, // true でスクリプトプロパティ SLACK_WEBHOOK_URL に通知
    // 1通ごとに通知すると多いので、まとめて「○件転記しました」を送る
    NOTIFY_SUMMARY: true,
  },

  // ── エラー通知先 ─────────────────────────────────────────
  ADMIN_EMAIL: Session.getActiveUser().getEmail(),
};

/** スクリプトプロパティから Slack Webhook URL を取得します。 */
function getSlackWebhookUrl_() {
  return PropertiesService.getScriptProperties().getProperty('SLACK_WEBHOOK_URL');
}
